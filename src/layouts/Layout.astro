---
export interface Props {
  title: string;
  description?: string;
}

const { title, description = "Sönke Nommensen - Engineering Team Lead & Software Developer" } = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Fonts: Instrument Serif (headlines), Plus Jakarta Sans (body), JetBrains Mono (code) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=JetBrains+Mono:wght@400;500&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />

    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <!-- Blocking script: detect theme before first paint to prevent FOUC -->
    <script is:inline>
      (function() {
        function getTheme() {
          var saved = localStorage.getItem('theme');
          if (saved === 'light' || saved === 'dark') return saved;
          if (window.matchMedia('(prefers-color-scheme: light)').matches) return 'light';
          if (window.matchMedia('(prefers-color-scheme: dark)').matches) return 'dark';
          var h = new Date().getHours();
          return (h >= 7 && h < 19) ? 'light' : 'dark';
        }
        var theme = getTheme();
        document.documentElement.dataset.theme = theme;
        window.matchMedia('(prefers-color-scheme: light)').addEventListener('change', function(e) {
          if (!localStorage.getItem('theme')) {
            document.documentElement.dataset.theme = e.matches ? 'light' : 'dark';
          }
        });
      })();
    </script>

    <style is:global>
      /* ── Theme tokens (dark = default) ── */
      :root,
      [data-theme="dark"] {
        --nordic-void: 10 10 12;
        --nordic-base: 15 15 18;
        --nordic-surface: 24 24 28;
        --nordic-elevated: 34 34 40;
        --nordic-card: 28 28 33;
        --nordic-border: 42 42 50;
        --nordic-border-subtle: 31 31 38;
        --nordic-text: 232 230 227;
        --nordic-text-secondary: 184 182 179;
        --nordic-muted: 122 122 127;
        --nordic-amber: 212 168 83;
        --nordic-amber-dim: 184 146 61;
        --nordic-amber-glow: rgba(212, 168, 83, 0.15);
        --nordic-sky: 126 181 214;
        --nordic-sky-dim: 90 155 196;
        --nordic-sage: 143 174 139;
        --nordic-rose: 196 139 139;
        --nordic-lavender: 168 156 196;
        --nordic-slate: 138 154 173;
      }

      [data-theme="light"] {
        --nordic-void: 245 242 237;
        --nordic-base: 250 248 245;
        --nordic-surface: 240 237 232;
        --nordic-elevated: 232 228 222;
        --nordic-card: 245 242 237;
        --nordic-border: 216 212 204;
        --nordic-border-subtle: 232 228 222;
        --nordic-text: 42 38 34;
        --nordic-text-secondary: 90 86 80;
        --nordic-muted: 154 150 144;
        --nordic-amber: 184 146 61;
        --nordic-amber-dim: 160 125 46;
        --nordic-amber-glow: rgba(184, 146, 61, 0.12);
        --nordic-sky: 74 143 184;
        --nordic-sky-dim: 58 125 166;
        --nordic-sage: 90 138 86;
        --nordic-rose: 160 96 96;
        --nordic-lavender: 122 109 160;
        --nordic-slate: 90 106 125;
      }

      /* Smooth theme transition */
      html {
        transition: background-color 0.3s ease, color 0.3s ease;
      }

      /* Base styles */
      html {
        font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }

      /* Selection color */
      ::selection {
        background: rgb(var(--nordic-amber) / 0.3);
        color: rgb(var(--nordic-text));
      }

      /* Scroll-triggered animation setup */
      .fade-in-section {
        opacity: 0;
        transform: translateY(30px);
        transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
      }

      .fade-in-section.is-visible {
        opacity: 1;
        transform: translateY(0);
      }

      /* Staggered animation delays for cards */
      .stagger-item {
        opacity: 0;
        transform: translateY(20px);
        transition: opacity 0.6s cubic-bezier(0.16, 1, 0.3, 1), transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
      }

      .stagger-item.is-visible {
        opacity: 1;
        transform: translateY(0);
      }

      .stagger-item:nth-child(1) { transition-delay: 0.1s; }
      .stagger-item:nth-child(2) { transition-delay: 0.2s; }
      .stagger-item:nth-child(3) { transition-delay: 0.3s; }
      .stagger-item:nth-child(4) { transition-delay: 0.4s; }
      .stagger-item:nth-child(5) { transition-delay: 0.5s; }
      .stagger-item:nth-child(6) { transition-delay: 0.6s; }

      /* Grain texture overlay - applied to sections */
      .grain-overlay::before {
        content: '';
        position: absolute;
        top: -50%;
        left: -50%;
        right: -50%;
        bottom: -50%;
        width: 200%;
        height: 200%;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 400 400' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
        opacity: 0.03;
        pointer-events: none;
        animation: grain 8s steps(10) infinite;
        z-index: 1;
      }

      @keyframes grain {
        0%, 100% { transform: translate(0, 0); }
        10% { transform: translate(-5%, -10%); }
        20% { transform: translate(-15%, 5%); }
        30% { transform: translate(7%, -25%); }
        40% { transform: translate(-5%, 25%); }
        50% { transform: translate(-15%, 10%); }
        60% { transform: translate(15%, 0%); }
        70% { transform: translate(0%, 15%); }
        80% { transform: translate(3%, 35%); }
        90% { transform: translate(-10%, 10%); }
      }

      /* Ensure content is above grain */
      .grain-overlay > * {
        position: relative;
        z-index: 2;
      }

      /* Typography utilities */
      .font-editorial {
        font-family: 'Instrument Serif', Georgia, serif;
      }

      .text-balance {
        text-wrap: balance;
      }

      /* Smooth focus states */
      *:focus-visible {
        outline: 2px solid rgb(var(--nordic-amber));
        outline-offset: 2px;
      }

      /* Link underline animation */
      .link-underline {
        position: relative;
        text-decoration: none;
      }

      .link-underline::after {
        content: '';
        position: absolute;
        width: 0;
        height: 1px;
        bottom: -2px;
        left: 0;
        background-color: currentColor;
        transition: width 0.3s cubic-bezier(0.16, 1, 0.3, 1);
      }

      .link-underline:hover::after {
        width: 100%;
      }

      /* Decorative line */
      .decorative-line {
        height: 1px;
        background: linear-gradient(90deg, transparent, rgb(var(--nordic-amber)) 50%, transparent);
      }

      /* Card glow effect on hover */
      .card-glow {
        transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
      }

      .card-glow:hover {
        box-shadow: 0 0 40px rgb(var(--nordic-amber) / 0.08), 0 0 80px rgb(var(--nordic-amber) / 0.04);
      }
    </style>
  </head>
  <body class="bg-nordic-base text-nordic-text antialiased overflow-x-hidden">
    <slot />

    <script>
      // Scroll-triggered animations
      const observerOptions = {
        threshold: 0.1,
        rootMargin: '0px 0px -50px 0px'
      };

      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
          }
        });
      }, observerOptions);

      // Observe all fade-in sections and stagger items
      document.addEventListener('DOMContentLoaded', () => {
        const fadeElements = document.querySelectorAll('.fade-in-section');
        const staggerElements = document.querySelectorAll('.stagger-item');

        fadeElements.forEach(el => observer.observe(el));
        staggerElements.forEach(el => observer.observe(el));
      });
    </script>
  </body>
</html>
