---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import Projects from '../components/Projects.astro';
import OffTheClock from '../components/OffTheClock.astro';
import Frames from '../components/Frames.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Sönke Nommensen',
  url: 'https://soenke.me/',
  jobTitle: 'Software Developer',
  address: { '@type': 'PostalAddress', addressLocality: 'Lübeck', addressCountry: 'DE' },
  email: 'mailto:hi@soenke.me',
  sameAs: [
    'https://github.com/soenkenils',
    'https://www.linkedin.com/in/s%C3%B6nke-nommensen-a1217525/',
  ],
};
---

<Layout title="Sönke Nommensen — Software Developer">
  <script type="application/ld+json" slot="head" is:inline set:html={JSON.stringify(personSchema)} />
  <Header />
  <main id="top">
    <Hero />
    <About />
    <Projects />
    <OffTheClock />
    <Frames />
    <Contact />
  </main>
  <Footer />
</Layout>
