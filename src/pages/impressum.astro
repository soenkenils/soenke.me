---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Impressum — Sönke Nommensen"
  description="Impressum von soenke.me — Angaben gemäß § 5 DDG."
  lang="de"
  noindex
>
  <Header />
  <main id="top">
    <section class="section" style="padding-top: clamp(120px, 18vh, 200px); min-height: 100svh;">
      <div class="wrap">
        <a href="/" class="link-ext" style="margin-top: 0; margin-bottom: 28px;">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" stroke-linecap="round" stroke-linejoin="round"></path></svg>
          Zurück
        </a>
        <div class="kicker"><span class="num">§5</span><span class="lbl">Impressum</span><span class="rule"></span></div>
        <h2 class="h2"><span class="g-cyan">Impressum</span></h2>

        <div class="tl-card" style="max-width: 560px;">
          <div class="k" style="font-size: 12px; letter-spacing: 0.22em; text-transform: uppercase; color: var(--ink-mut); margin-bottom: 16px;">
            Angaben gemäß § 5 DDG
          </div>
          <p style="margin: 0 0 4px; color: var(--ink-soft);">Sönke Nommensen</p>
          <p style="margin: 0 0 4px; color: var(--ink-soft);">Herderplatz 5a</p>
          <p style="margin: 0 0 18px; color: var(--ink-soft);">23564 Lübeck</p>
          <a class="hero-sub" style="margin: 0;" href="mailto:hi@soenke.me"><span style="color: var(--yellow);">hi@soenke.me</span></a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
