---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Impressum — Sönke Nommensen"
  description="Impressum von soenke.me — Angaben gemäß § 5 DDG."
  lang="de"
  noindex
>
  <Header />
  <main id="top">
    <section class="section legal">
      <div class="wrap">
        <a href="/" class="link-ext back">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" stroke-linecap="round" stroke-linejoin="round"></path></svg>
          Zurück
        </a>
        <div class="kicker"><span class="num">§5</span><span class="lbl">Impressum</span><span class="rule"></span></div>
        <h2 class="h2"><span class="g-cyan">Impressum</span></h2>

        <div class="legal-card">
          <div class="k">Angaben gemäß § 5 DDG</div>
          <p>Sönke Nommensen</p>
          <p>Herderplatz 5a</p>
          <p>23564 Lübeck</p>
          <a class="mail" href="mailto:hi@soenke.me">hi@soenke.me</a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
