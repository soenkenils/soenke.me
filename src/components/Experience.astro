---
---

<section id="experience" class="py-24 md:py-32 bg-nordic-base relative overflow-hidden grain-overlay">
  <div class="container mx-auto px-6 relative z-10">
    <!-- Section header -->
    <div class="max-w-4xl mx-auto mb-16 fade-in-section">
      <div class="flex items-center gap-4 mb-6">
        <span class="text-nordic-amber font-mono text-sm tracking-wider">02</span>
        <span class="w-12 h-px bg-nordic-border" aria-hidden="true"></span>
      </div>
      <h2 class="text-4xl md:text-5xl font-serif italic text-nordic-text mb-4">
        Experience
      </h2>
    </div>

    <div class="max-w-4xl mx-auto">
      <!-- Timeline -->
      <div class="relative">
        <!-- Timeline line -->
        <div class="absolute left-0 md:left-8 top-0 bottom-0 w-px bg-gradient-to-b from-nordic-amber via-nordic-border to-transparent" aria-hidden="true"></div>

        <div class="space-y-12">
          <!-- Current role: Engineering Team Lead @ Tomorrow -->
          <div class="relative pl-8 md:pl-20 stagger-item">
            <div class="absolute left-0 md:left-8 top-2 -translate-x-1/2" aria-hidden="true">
              <div class="relative">
                <div class="w-4 h-4 rounded-full bg-nordic-amber shadow-lg shadow-nordic-amber/30"></div>
                <div class="absolute inset-0 w-4 h-4 rounded-full bg-nordic-amber/50 animate-ping"></div>
              </div>
            </div>

            <div class="group bg-nordic-card border border-nordic-border/50 rounded-xl p-6 md:p-8 transition-all duration-300 hover:border-nordic-amber/30 card-glow">
              <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-4 mb-4">
                <div>
                  <h3 class="text-xl md:text-2xl font-medium text-nordic-text mb-1">Engineering Team Lead</h3>
                  <p class="text-nordic-amber font-medium">Tomorrow</p>
                </div>
                <div class="flex items-center gap-3">
                  <span class="text-nordic-muted text-sm font-mono">2024 — Present</span>
                  <span class="inline-flex items-center gap-2 bg-nordic-amber/10 text-nordic-amber px-3 py-1 rounded-full text-sm font-medium w-fit">
                    <span class="w-1.5 h-1.5 rounded-full bg-nordic-amber animate-pulse" aria-hidden="true"></span>
                    Current
                  </span>
                </div>
              </div>

              <p class="text-nordic-muted leading-relaxed mb-6">
                Leading the engineering team building Tomorrow's mobile banking platform. I spend my days on system design, code reviews, and helping my team ship features without breaking prod.
              </p>

              <div class="flex flex-wrap gap-2">
                <span class="text-xs font-mono text-nordic-text-secondary bg-nordic-surface/50 px-3 py-1 rounded-md border border-nordic-border/30">
                  Leadership
                </span>
                <span class="text-xs font-mono text-nordic-text-secondary bg-nordic-surface/50 px-3 py-1 rounded-md border border-nordic-border/30">
                  FinTech
                </span>
                <span class="text-xs font-mono text-nordic-text-secondary bg-nordic-surface/50 px-3 py-1 rounded-md border border-nordic-border/30">
                  Hands-on Technical Leadership
                </span>
              </div>
            </div>
          </div>

          <!-- Background summary -->
          <div class="relative pl-8 md:pl-20 stagger-item">
            <div class="absolute left-0 md:left-8 top-2 -translate-x-1/2" aria-hidden="true">
              <div class="w-3 h-3 rounded-full bg-nordic-border border-2 border-nordic-base"></div>
            </div>

            <div class="group bg-nordic-card/50 border border-nordic-border/30 rounded-xl p-6 md:p-8 transition-all duration-300 hover:border-nordic-muted/30 hover:bg-nordic-card">
              <div class="mb-4">
                <h3 class="text-xl font-medium text-nordic-text-secondary mb-2">Previously</h3>
              </div>

              <p class="text-nordic-muted leading-relaxed mb-6">
                Over 13 years of building software across FinTech, InsurTech, and safety-critical domains. I've been a senior engineer at Tomorrow, led my first engineering team at ELEMENT Insurance, and spent six years at Dräger working on medical and safety technology where reliability isn't optional. The thread through it all: writing code that matters, and eventually learning that growing people matters just as much.
              </p>

              <div class="flex flex-wrap gap-2 mb-6">
                <span class="text-xs font-mono text-nordic-muted bg-nordic-surface/30 px-3 py-1 rounded-md border border-nordic-border/20">
                  Tomorrow
                </span>
                <span class="text-xs font-mono text-nordic-muted bg-nordic-surface/30 px-3 py-1 rounded-md border border-nordic-border/20">
                  ELEMENT Insurance
                </span>
                <span class="text-xs font-mono text-nordic-muted bg-nordic-surface/30 px-3 py-1 rounded-md border border-nordic-border/20">
                  Dräger
                </span>
              </div>

              <a
                href="https://www.linkedin.com/in/s%C3%B6nke-nommensen-a1217525/"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 text-nordic-sky hover:text-nordic-amber transition-colors duration-300 text-sm link-underline"
              >
                Full history on LinkedIn
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"></path>
                </svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
