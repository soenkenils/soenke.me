---
// nav links use "/#id" (not "#id") so they also work from /impressum and /404
const links = [
  { href: '/#about', label: 'About' },
  { href: '/#work', label: 'Work' },
  { href: '/#experience', label: 'Experience' },
  { href: '/#play', label: 'Off the clock' },
];
const cta = { href: '/#contact', label: 'Say hi' };
---

<header class="nav">
  <nav class="wrap nav-inner">
    <a href="/#top" class="logo"><span class="dot"></span><span class="word"><b>soenke</b><span class="me">.me</span></span></a>
    <div class="nav-links">
      {links.map((l) => <a href={l.href}>{l.label}</a>)}
      <a href={cta.href} class="nav-cta">{cta.label}</a>
    </div>
    <button class="burger" id="burger" aria-label="Open menu" aria-expanded="false" aria-controls="mobileMenu">
      <span></span><span></span><span></span>
    </button>
  </nav>
</header>
<div class="mobile-menu" id="mobileMenu">
  {[...links, cta].map((l) => <a href={l.href}>{l.label}</a>)}
</div>
