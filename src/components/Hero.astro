<section class="hero" id="hero">
  <div class="hero-sky" aria-hidden="true">
    <div class="stars" id="stars"></div>
    <div class="sun"><div class="bands"></div></div>
    <div class="mtn"></div>
  </div>
  <div class="grid-floor" aria-hidden="true"></div>

  <div class="hero-content">
    <div class="role-badge"><b></b>Moin from Lübeck</div>
    <h1>
      <span class="g-pink flicker">SÖNKE</span>
      <span class="l2 g-cyan">NOMMENSEN</span>
    </h1>
    <p class="hero-sub">
      Software developer from Lübeck — also a coffee nerd and steel-bike rider. You'll find me
      dialing in a pour-over, out on a road bike, or somewhere with a camera.
    </p>
    <div class="hero-actions">
      <a href="#contact" class="btn-pink">SAY HELLO ▸</a>
      <a href="#about" class="scroll-hint">↓ scroll to explore</a>
    </div>
  </div>

  <div class="hero-ticker" aria-hidden="true">
    <span>Filter coffee</span><span class="sep">◆</span>
    <span>Steel &amp; tarmac</span><span class="sep">◆</span>
    <span>Fujifilm frames</span>
  </div>
</section>
