<section class="hero" id="hero">
  <div class="hero-sky" aria-hidden="true">
    <div class="stars" id="stars"></div>
    <div class="sun"><div class="bands"></div></div>
    <div class="mtn"></div>
  </div>
  <div class="grid-floor" aria-hidden="true"></div>

  <div class="hero-content">
    <div class="role-badge"><b></b>Engineering Team Lead</div>
    <h1>
      <span class="g-pink flicker">SÖNKE</span>
      <span class="l2 g-cyan">NOMMENSEN</span>
    </h1>
    <p class="hero-sub">
      I lead the engineers building mobile banking at <a href="https://www.tomorrow.one" target="_blank" rel="noopener">Tomorrow</a>.
      Off the clock you'll find me dialing in a pour-over, out on a steel road bike, or chasing my kids around with a camera.
    </p>
    <div class="hero-actions">
      <a href="#contact" class="btn-pink">SAY HELLO ▸</a>
      <a href="#about" class="scroll-hint">↓ scroll to explore</a>
    </div>
  </div>

  <div class="hero-ticker" aria-hidden="true">
    <span>Filter coffee</span><span class="sep">◆</span>
    <span>Steel &amp; tarmac</span><span class="sep">◆</span>
    <span>Fujifilm frames</span>
  </div>
</section>
