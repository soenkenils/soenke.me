---
import Icon from './Icon.astro';
---

<section class="section" id="contact">
  <div class="wrap">
    <div class="kicker reveal"><span class="num">05</span><span class="lbl">Contact</span><span class="rule"></span></div>
    <h2 class="h2 reveal">Let's <span class="g-cyan">say hello</span></h2>
    <p class="lead reveal d1" style="margin-bottom:34px;">Working on something interesting, hiring, or just want to talk coffee and bikes? My inbox is open.</p>
    <div class="contact-cards">
      <a class="ccard reveal d1" style="--accent: var(--pink);" href="mailto:hi@soenke.me">
        <span class="ic"><Icon name="email" size={20} /></span>
        <div><div class="k">Email</div><div class="s">hi@soenke.me</div></div>
      </a>
      <a class="ccard reveal d2" style="--accent: var(--cyan);" href="https://github.com/soenkenils" target="_blank" rel="noopener">
        <span class="ic"><Icon name="github" size={20} /></span>
        <div><div class="k">GitHub</div><div class="s">@soenkenils</div></div>
      </a>
      <a class="ccard reveal d3" style="--accent: var(--purple);" href="https://www.linkedin.com/in/s%C3%B6nke-nommensen-a1217525/" target="_blank" rel="noopener">
        <span class="ic"><Icon name="linkedin" size={20} /></span>
        <div><div class="k">LinkedIn</div><div class="s">View profile</div></div>
      </a>
    </div>
    <div class="loc reveal d2">
      <span>Based in Lübeck, Germany</span><span class="d"></span><span>Open to remote</span>
    </div>
  </div>
</section>
